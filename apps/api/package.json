{
  "name": "@mmhack/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --max-warnings 0",
    "start": "node dist/src/server.js",
    "test": "vitest run --pool=threads src/app.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mmhack/agent": "workspace:*",
    "@mmhack/ai": "workspace:*",
    "@mmhack/recipes": "workspace:*",
    "@mmhack/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3"
  }
}
