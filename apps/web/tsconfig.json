{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "incremental": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@mmhack/ai": [
        "../../packages/ai/src/index.ts"
      ],
      "@mmhack/db": [
        "../../packages/db/src/index.ts"
      ],
      "@mmhack/pricing": [
        "../../packages/pricing/src/index.ts"
      ],
      "@mmhack/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@mmhack/vori": [
        "../../packages/vori/src/index.ts"
      ]
    },
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
