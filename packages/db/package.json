{
  "name": "@mmhack/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "db:test:prepare": "cross-env DATABASE_URL=file:./test.db prisma db push --force-reset --skip-generate --schema prisma/schema.prisma",
    "lint": "eslint src --max-warnings 0",
    "test": "pnpm run db:test:prepare && cross-env DATABASE_URL=file:./test.db vitest run --pool=threads src/index.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@mmhack/shared": "workspace:*",
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
